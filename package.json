{
  "name": "autovestai-trading-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Production-grade CFD trading backend for AutovestAI",
  "license": "UNLICENSED",
  "scripts": {
    "prebuild": "node scripts/clean-backend-build.js",
    "build": "nest build",
    "start": "node dist/main.js",
    "start:prod": "node dist/main",
    "prestart:dev": "node scripts/clean-backend-build.js",
    "start:dev": "nest start --watch",
    "postinstall": "npx prisma generate",
    "lint": "tsc --noEmit",
